# ─────────────────────────────────────────────────────────────
# Travel With Mia — environment variables
# Copy to `.env.local` and fill in. The site RUNS without these
# (forms fall back to a local log), but data won't persist and
# auth is disabled until Supabase keys are set.
# ─────────────────────────────────────────────────────────────

# Public site URL (canonical/OG tags, sitemap). On Vercel this is auto-detected
# from the deployment URL, but SET IT to your real domain for best SEO:
NEXT_PUBLIC_SITE_URL=https://travelwithmia.co.uk

# ── Business details (shown on the site — fill in to go fully live) ──
# Anything left blank shows an honest fallback instead of a fake value.
NEXT_PUBLIC_CONTACT_EMAIL=hello@travelwithmia.co.uk
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_MIA_WHATSAPP_NUMBER=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TIKTOK_URL=

# Trader identity + financial protection (server-side).
# ⚠️ NEVER invent an ATOL/ABTA number — leave blank until you have the real one.
COMPANY_LEGAL_NAME=
COMPANY_NUMBER=
COMPANY_ADDRESS=
VAT_NUMBER=
ATOL_NUMBER=
ABTA_NUMBER=

# ── Search Console / SEO verification ───────────────────────
# Paste the token from Google Search Console (HTML tag method) to verify the
# site and get it indexed so it appears in Google/Safari search.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Supabase (auth + Postgres) ──────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose to the browser. Used by API routes to
# write quotes/enquiries and manage accounts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Google OAuth (optional social login) ────────────────────
# Configured in Supabase → Authentication → Providers → Google.
# These are only needed if you wire up your own OAuth flow.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Stripe Payment Links (hosted pages only — no raw cards) ──
# Paste your hosted Payment Link URLs. Leave blank to hide buttons.
NEXT_PUBLIC_STRIPE_VIP_PAYMENT_LINK=

# ── Flight search — Amadeus Self-Service (FREE test tier) ───
# 1. Sign up free at https://developers.amadeus.com
# 2. My Self-Service Workspace → create an App → copy the keys below.
# 3. Leave AMADEUS_ENV=test to use the free sandbox (real cached data).
# Without these, flight search returns clearly-labelled SAMPLE results.
AMADEUS_CLIENT_ID=your-amadeus-api-key
AMADEUS_CLIENT_SECRET=your-amadeus-api-secret
AMADEUS_ENV=test

# ── Admin back office ───────────────────────────────────────
# The access code Mia types to open /admin, and a random secret used to
# sign the admin session cookie. CHANGE BOTH before going public.
# Generate a secret with:  openssl rand -hex 32
ADMIN_ACCESS_CODE=mia-admin
ADMIN_SESSION_SECRET=please-generate-a-long-random-secret

# ── Contact / notifications (optional) ──────────────────────
# Where new enquiry notifications should be emailed. Placeholder only.
ENQUIRY_NOTIFY_EMAIL=hello@travelwithmia.example
